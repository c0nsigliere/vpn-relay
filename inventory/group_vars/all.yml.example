---
# =============================================================================
# WireGuard Cascade VPN Configuration
# Copy this file to all.yml and fill in your values.
# =============================================================================

# =============================================================================
# WireGuard cascade — network addressing
# =============================================================================

# Client-facing WireGuard interface on Server A
wg_clients_net: "10.66.0.0/24"
wg_clients_addr_a: "10.66.0.1/24"
wg_clients_port: 51888            # UDP port clients connect to on Server A

# Uplink tunnel between Server A and Server B
wg_uplink_net: "10.200.0.0/30"
wg_uplink_addr_a: "10.200.0.1/30"
wg_uplink_addr_b: "10.200.0.2/30"
wg_uplink_port_b: 51821           # UDP port Server B listens on for uplink (not 51820 — that's Amnezia's default)

# Server B WAN IP — REQUIRED (the public IP clients cannot reach directly)
ip_b_public: "YOUR_SERVER_B_PUBLIC_IP"

# DNS servers embedded in generated client .conf files
wg_client_dns: "1.1.1.1,1.0.0.1"

# WAN interface override (leave commented for auto-detection)
# wan_if: "eth0"

# Firewall management mode: "keep" (UFW) or "disable" (iptables-persistent)
manage_ufw: "keep"

# =============================================================================
# Legacy XRay relay configuration (used with playbooks/relay.yml)
# Keep these if you still run Server A as an XRay relay.
# =============================================================================
ip_b: "YOUR_VPN_SERVER_IP"
port_a_udp: 51821
port_a_tcp: 8443
port_b_udp: 51820
port_b_tcp: 443

# =============================================================================
# Maintenance configuration
# =============================================================================

# Perform dist-upgrade during maintenance (may remove packages).
# Default: false (safe upgrade only — never removes packages).
do_dist_upgrade: false

# Manage unattended-upgrades:
#   "leave"  - Do not touch existing config (recommended for relay nodes)
#   "true"   - Enable automatic background updates
#   "false"  - Disable automatic background updates
manage_unattended_upgrades: "leave"

# Reboot after maintenance if /var/run/reboot-required exists.
maintenance_reboot: true
