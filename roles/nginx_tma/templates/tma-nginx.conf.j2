# TMA Web App — nginx config
# Generated by Ansible (roles/nginx_tma)
# Listens on port {{ tma_https_port }} (HTTPS) to avoid conflict with XRay on 443.

{% if tma_ssl_ready | default(false) %}
server {
    listen 80;
    server_name {{ tma_domain }};
    return 301 https://$host:{{ tma_https_port }}$request_uri;
}

server {
    listen {{ tma_https_port }} ssl;
    server_name {{ tma_domain }};

    ssl_certificate     /etc/letsencrypt/live/{{ tma_domain }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ tma_domain }}/privkey.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    # Proxy API requests to Fastify
    location /api/ {
        proxy_pass http://127.0.0.1:{{ tma_backend_port }};
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_cache_bypass $http_upgrade;
    }

    # Serve React SPA static files
    location / {
        proxy_pass http://127.0.0.1:{{ tma_backend_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
{% else %}
# Temporary HTTP-only config until certbot obtains SSL certificate
server {
    listen 80;
    server_name {{ tma_domain }};

    location / {
        proxy_pass http://127.0.0.1:{{ tma_backend_port }};
        proxy_http_version 1.1;
        proxy_set_header Host $host;
    }
}
{% endif %}
