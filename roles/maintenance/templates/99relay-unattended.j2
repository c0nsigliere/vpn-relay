// /etc/apt/apt.conf.d/99relay-unattended
// Managed by Ansible (roles/maintenance). DO NOT EDIT MANUALLY.
//
// Overlay on top of 50unattended-upgrades. Read last (99 > 50).
// ${distro_id}/${distro_codename} are expanded by the unattended-upgrades
// daemon at runtime, not by APT — so we keep them as variables.

Unattended-Upgrade::Allowed-Origins {
    "${distro_id}:${distro_codename}-security";
    "${distro_id}ESMApps:${distro_codename}-apps-security";
    "${distro_id}ESM:${distro_codename}-infra-security";
};

// Never reboot automatically.
// Rebooting drops WireGuard tunnels without warning.
// Managed via: ansible-playbook playbooks/reboot-if-needed.yml
Unattended-Upgrade::Automatic-Reboot "false";

// Log to syslog: journalctl -u unattended-upgrades
Unattended-Upgrade::SyslogEnable "true";
Unattended-Upgrade::SyslogFacility "daemon";

// Remove old kernels (safe with Automatic-Reboot=false: files are deleted,
// the running kernel continues until the next manual reboot)
Unattended-Upgrade::Remove-Unused-Kernel-Packages "true";
Unattended-Upgrade::Remove-Unused-Dependencies "true";
