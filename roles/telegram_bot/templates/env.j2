# VPN Bot environment — generated by Ansible, do not edit manually
BOT_TOKEN={{ bot_telegram_token }}
ADMIN_ID={{ bot_admin_id }}

# Database
DB_PATH={{ bot_data_dir }}/data.db

# Server A (WireGuard, SSH)
SERVER_A_HOST={{ hostvars[groups['server_a'][0]]['ansible_host'] }}
SERVER_A_SSH_PORT=22
SERVER_A_SSH_USER={{ hostvars[groups['server_a'][0]]['ansible_user'] | default('root') }}
SERVER_A_SSH_KEY_PATH={{ bot_ssh_key_path }}
SERVER_A_WG_PORT={{ wg_clients_port | default(51888) }}
SERVER_A_RELAY_PORT={{ port_a_tcp | default(443) }}

# Server B (local XRay)
SERVER_B_HOST={{ server_b_public_ip }}
SERVER_B_XRAY_PORT={{ xray_port | default(8443) }}
XRAY_API_PORT={{ xray_api_port }}
XRAY_KEYS_DIR={{ xray_keys_dir }}
XRAY_CLIENTS_FILE={{ xray_clients_file }}

# XRay DPI evasion
XRAY_SNI={{ xray_sni }}
XRAY_FINGERPRINT={{ xray_fingerprint }}
XRAY_FLOW={{ xray_flow }}
