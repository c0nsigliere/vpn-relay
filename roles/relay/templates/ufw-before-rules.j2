{#
  Template reference for UFW before.rules NAT section.
  This template is NOT used directly - blockinfile is used instead.
  Kept as documentation/reference for the NAT rules structure.
#}

# BEGIN VPN-RELAY NAT RULES
*nat
:PREROUTING ACCEPT [0:0]
:POSTROUTING ACCEPT [0:0]
# TCP relay (XRay)
-A PREROUTING -i {{ wan_if_final }} -p tcp --dport {{ port_a_tcp }} -j DNAT --to-destination {{ server_b_public_ip }}:{{ port_b_tcp }}
-A POSTROUTING -o {{ wan_if_final }} -p tcp -d {{ server_b_public_ip }} --dport {{ port_b_tcp }} -j MASQUERADE
COMMIT
# END VPN-RELAY NAT RULES

{#
  FORWARD rules (added to *filter section, ufw-before-forward chain):

  # BEGIN VPN-RELAY FORWARD RULES
  # TCP forward to Server B
  -A ufw-before-forward -i {{ wan_if_final }} -p tcp -d {{ server_b_public_ip }} --dport {{ port_b_tcp }} -j ACCEPT
  # TCP forward from Server B (established/related)
  -A ufw-before-forward -i {{ wan_if_final }} -p tcp -s {{ server_b_public_ip }} --sport {{ port_b_tcp }} -m conntrack --ctstate ESTABLISHED,RELATED -j ACCEPT
  # END VPN-RELAY FORWARD RULES
#}
