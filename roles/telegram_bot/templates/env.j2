# VPN Bot environment — generated by Ansible, do not edit manually
BOT_TOKEN={{ bot_telegram_token }}
ADMIN_ID={{ bot_admin_id }}

# Database
DB_PATH={{ bot_data_dir }}/data.db

# Server A (WireGuard, SSH)
SERVER_A_HOST={{ hostvars[groups['server_a'][0]]['ansible_host'] }}
SERVER_A_SSH_PORT=22
SERVER_A_SSH_USER={{ hostvars[groups['server_a'][0]]['ansible_user'] | default('root') }}
SERVER_A_SSH_KEY_PATH={{ bot_ssh_key_path }}
SERVER_A_WG_PORT={{ wg_clients_port }}
SERVER_A_RELAY_PORT={{ port_a_tcp }}

# Server B (local XRay)
SERVER_B_HOST={{ server_b_public_ip }}
SERVER_B_XRAY_PORT={{ xray_port }}
XRAY_API_PORT={{ xray_api_port }}
XRAY_KEYS_DIR={{ xray_keys_dir }}
XRAY_WG_UPLINK_UUID={{ xray_wg_uplink_uuid }}

# XRay DPI evasion
XRAY_SNI={{ xray_sni }}
XRAY_FINGERPRINT={{ xray_fingerprint }}
XRAY_FLOW={{ xray_flow }}

# OpenAI (optional — enriched update summaries)
{% if openai_api_key is defined and openai_api_key | length > 0 %}
OPENAI_API_KEY={{ openai_api_key }}
{% endif %}

# TMA (Telegram Mini App)
TMA_PORT={{ tma_backend_port }}
{% if tma_domain | length > 0 %}
TMA_DOMAIN={{ tma_domain }}
TMA_URL=https://{{ tma_domain }}:{{ tma_https_port }}
{% endif %}
