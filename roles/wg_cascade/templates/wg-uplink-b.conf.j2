# /etc/wireguard/wg-uplink.conf (Server B)
# Managed by Ansible wg_cascade role (roles/wg_cascade/tasks/configs.yml)
#
# Server B receives the cascade uplink from Server A.
# NAT (MASQUERADE) for client traffic is handled in firewall_keep.yml / firewall_disable.yml.

[Interface]
Address    = {{ wg_uplink_addr_b }}
ListenPort = {{ wg_uplink_port_b }}
PrivateKey = {{ _wg_uplink_privkey_b.content | b64decode | trim }}

[Peer]
# Server A — uplink initiator
PublicKey           = {{ _wg_a_uplink_pubkey.content | b64decode | trim }}
# AllowedIPs: accept Server A's uplink address AND the full client subnet
# (Server B must accept packets from all clients, not just 10.200.0.1)
AllowedIPs          = {{ wg_uplink_addr_a | regex_replace('/\d+$', '/32') }}, {{ wg_clients_net }}
PersistentKeepalive = 25
