# =============================================================================
# VPN Relay & WireGuard Cascade — Inventory
# =============================================================================
# Copy to: inventory/inventory.ini and fill in real IP addresses.
#
# Default setup uses both features on the same server pair:
#   Server A — relay entry point + cascade node A
#   Server B — VPN endpoint + cascade node B

# --- Host definitions (fill in real IPs) ---
[server_a]
server-a  ansible_host=YOUR_SERVER_A_IP

[server_b]
server-b  ansible_host=YOUR_SERVER_B_IP

# --- WireGuard Cascade: targets BOTH Server A and Server B ---
# Playbooks: cascade.yml, verify_cascade.yml, rollback_cascade.yml,
#            add_client.yml, maintenance_add_swap.yml
# Vars:      inventory/group_vars/wg_cascade.yml
[wg_cascade:children]
server_a
server_b

[wg_cascade:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_user=root

# --- XRay L4 Relay (TCP): targets Server A ONLY ---
# Playbooks: relay.yml, rollback.yml
# Vars:      inventory/group_vars/relay_servers.yml
[relay_servers:children]
server_a

[relay_servers:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_user=root

# --- XRay VLESS+Reality Server: targets Server B ONLY ---
# Playbooks: xray.yml, add_xray_user.yml, verify_xray.yml, rollback_xray.yml
# Vars:      inventory/group_vars/xray_servers.yml
[xray_servers:children]
server_b

[xray_servers:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_user=root
