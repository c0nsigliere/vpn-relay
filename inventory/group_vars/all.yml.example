---
# VPN Relay Configuration
# Copy this file to all.yml and fill in your values.
# Override these in host_vars or inventory as needed.

# Target VPN server (Server B) IP address - REQUIRED
ip_b: "YOUR_VPN_SERVER_IP"

# Entry ports on relay server (Server A)
port_a_udp: 51821
port_a_tcp: 8443

# Target ports on VPN server (Server B)
port_b_udp: 51820
port_b_tcp: 443

# WAN interface (leave empty for auto-detection)
# wan_if: ""

# Firewall management mode: "keep" or "disable"
# - keep: Use UFW with NAT rules in before.rules
# - disable: Disable UFW, use iptables-persistent
manage_ufw: "keep"

# =============================================================================
# Maintenance configuration
# =============================================================================

# Perform dist-upgrade during maintenance (may remove packages to resolve
# dependency conflicts). Default: false (safe upgrade only - never removes).
# Override at runtime: -e "do_dist_upgrade=true"
do_dist_upgrade: false

# Manage the unattended-upgrades package:
#   "leave"  - Do not touch existing configuration (recommended for relay nodes)
#   "true"   - Install and enable automatic background updates
#   "false"  - Disable automatic background updates
# Relay nodes: "leave" or "false" strongly recommended. Automatic reboots
# from unattended-upgrades will drop all active VPN tunnels without warning.
manage_unattended_upgrades: "leave"

# Reboot after maintenance if /var/run/reboot-required exists.
# Default: true (necessary for kernel updates to take effect).
# Set false to defer reboots: -e "maintenance_reboot=false"
maintenance_reboot: true
