# =============================================================================
# WireGuard Cascade VPN — Inventory
# =============================================================================
# Copy this file to inventory.ini and fill in real IP addresses.

# --- WireGuard cascade servers ---
[server_a]
server-a  ansible_host=YOUR_SERVER_A_IP

[server_b]
server-b  ansible_host=YOUR_SERVER_B_IP

[wg_cascade:children]
server_a
server_b

[wg_cascade:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_user=root
# ansible_password=  # (less secure — prefer SSH keys)

# =============================================================================
# Legacy XRay relay (Server A only — used with playbooks/relay.yml)
# =============================================================================
[relay_servers]
relay1  ansible_host=YOUR_SERVER_A_IP

[relay_servers:vars]
ansible_python_interpreter=/usr/bin/python3
ansible_user=root
