---
# Shared Variables (all hosts)
# Copy to: inventory/group_vars/all.yml
#
# Role-specific vars go in their own files:
#   wg_cascade.yml   — cascade settings (from wg_cascade.yml.example)
#   relay_servers.yml — relay settings   (from relay_servers.yml.example)

# --- REQUIRED: Server B public IP (used by both cascade and relay) ---
server_b_public_ip: "YOUR_SERVER_B_PUBLIC_IP"

# --- REQUIRED: UUID authenticating Server A's XRay to Server B's XRay ---
# Generate with: python3 -c "import uuid; print(uuid.uuid4())"
xray_wg_uplink_uuid: "YOUR_UUID_HERE"

# --- Firewall mode (used by both roles) ---
# "keep"    — UFW stays enabled; NAT rules in /etc/ufw/before.rules
# "disable" — UFW disabled; rules via iptables-persistent
manage_ufw: "keep"

# --- WAN interface override (comment out for auto-detection) ---
# wan_if: "eth0"

# --- Maintenance ---
do_dist_upgrade: false
manage_unattended_upgrades: "leave"
maintenance_reboot: true
