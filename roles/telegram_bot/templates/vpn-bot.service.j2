[Unit]
Description=VPN Control Plane Telegram Bot
After=network.target xray.service
Requires=network.target

[Service]
Type=simple
User={{ bot_user }}
Group={{ bot_group }}
WorkingDirectory={{ bot_app_dir }}
EnvironmentFile={{ bot_app_dir }}/.env
ExecStart=/usr/bin/node packages/server/dist/index.js
Restart=always
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=vpn-bot

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ReadWritePaths={{ bot_data_dir }} {{ xray_config_dir }}
RuntimeDirectory=vpn-bot
RuntimeDirectoryMode=0755

[Install]
WantedBy=multi-user.target
