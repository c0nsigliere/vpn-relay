# WireGuard client configuration
# Generated by playbooks/add_client.yml
# Client: {{ client_name }}
# Generated: {{ ansible_date_time.date }}
#
# Install this file in your WireGuard client app or:
#   sudo cp {{ client_name }}.conf /etc/wireguard/wg0.conf
#   sudo wg-quick up wg0

[Interface]
Address    = {{ client_ip }}/32
PrivateKey = {{ client_privkey }}
DNS        = {{ wg_client_dns }}

[Peer]
# Server A — cascade VPN entry point
PublicKey           = {{ wg_clients_server_pubkey }}
Endpoint            = {{ hostvars[groups['server_a'][0]]['ansible_host'] }}:{{ wg_clients_port }}
AllowedIPs          = 0.0.0.0/0
PersistentKeepalive = 25
