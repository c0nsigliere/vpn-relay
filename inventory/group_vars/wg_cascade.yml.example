---
# WireGuard Cascade Variables (wg_cascade group: Server A + Server B)
# Copy to: inventory/group_vars/wg_cascade.yml

# Client-facing interface on Server A
wg_clients_net: "10.66.0.0/24"
wg_clients_addr_a: "10.66.0.1/24"
wg_clients_port: 51888

# Uplink tunnel between A and B
wg_uplink_net: "10.200.0.0/30"
wg_uplink_addr_a: "10.200.0.1/30"
wg_uplink_addr_b: "10.200.0.2/30"
wg_uplink_port_b: 51821         # Avoid 51820 (WireGuard default, often in use)

# DNS embedded in generated client configs
wg_client_dns: "1.1.1.1,1.0.0.1"
