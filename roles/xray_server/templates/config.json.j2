{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "listen": "0.0.0.0",
      "port": {{ xray_port }},
      "protocol": "vless",
      "settings": {
        "clients": [
{% for client in _xray_clients %}
          {
            "id": "{{ client.uuid }}",
            "email": "{{ client.name }}@xray"{% if xray_vless_flow | length > 0 %},
            "flow": "{{ xray_vless_flow }}"{% endif %}

          }{% if not loop.last or (xray_wg_uplink_uuid | default('') | length > 0) %},{% endif %}

{% endfor %}
{% if xray_wg_uplink_uuid | default('') | length > 0 %}
          {
            "id": "{{ xray_wg_uplink_uuid }}",
            "email": "wg-clients@xray"
          }
{% endif %}
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "{{ xray_reality_dest }}",
          "xver": 0,
          "serverNames": {{ xray_reality_server_names | to_json }},
          "privateKey": "{{ _xray_reality_privkey }}",
          "shortIds": [
            "{{ _xray_shortid }}"
          ]
        }
      },
      "sniffing": {
        "enabled": true,
        "destOverride": [
          "http",
          "tls",
          "quic"
        ]
      }
    }
  ],
  "outbounds": [
    {
      "protocol": "freedom",
      "tag": "direct",
      "settings": {
        "domainStrategy": "UseIPv4"
      }
    },
    {
      "protocol": "blackhole",
      "tag": "block"
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "ip": ["::/0"],
        "outboundTag": "block"
      }
    ]
  }
}
