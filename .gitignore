# Ansible inventory with real server addresses
inventory/inventory.ini
inventory/host_vars/

# Local variable overrides with real IPs and credentials
inventory/group_vars/all.yml
inventory/group_vars/wg_cascade.yml
inventory/group_vars/relay_servers.yml
inventory/group_vars/xray_servers.yml

# XRay/V2Ray client config with real credentials
config.json
config_awg.ini

# Ansible runtime files
*.retry
.ansible/

# Claude Code IDE settings
.claude/

# Generated client WireGuard configs and key material (sensitive)
artifacts/clients/*.conf
artifacts/clients/*.key

# Generated XRay client artifacts (sensitive)
artifacts/xray/*.vless.txt
artifacts/xray/*.json
artifacts/xray/*.qr.png

# Server state backups (keys, configs, bot DB)
artifacts/backup/

# Telegram bot
bot/node_modules/
bot/dist/
bot/packages/*/dist/
bot/packages/*/*.tsbuildinfo
bot/.env
bot/*.db
